<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_bottom_sheet_white">
    
    <View
        android:id="@+id/handleBar"
        android:layout_width="40dp"
        android:layout_height="5dp"
        android:background="@drawable/bg_handle_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        />
    <FrameLayout
        android:id="@+id/iconArea"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_circle_sheet_white"
        android:backgroundTint="@color/grayblue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/handleBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/round_check_circle_24"
            android:layout_gravity="center"/>
    </FrameLayout>

    <TextView
        android:id="@+id/idFindSuccessTextview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="아이디 찾기 완료"
        android:textSize="24dp"
        app:layout_constraintTop_toBottomOf="@id/iconArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/pretendard_bold"
        />

    <TextView
        android:id="@+id/idFindSuccessinfoTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="입력하신 정보와 일치하는 아이디입니다."
        app:layout_constraintTop_toBottomOf="@id/idFindSuccessTextview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:textColor="@color/textgray"
        android:fontFamily="@font/pretendard_medium"
        android:textSize="16dp"
        />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/resultBox"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        app:layout_constraintTop_toBottomOf="@id/idFindSuccessinfoTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_rounded_edittext"
        android:backgroundTint="@color/gray"
        android:layout_marginHorizontal="24dp">
        <TextView
            android:id="@+id/foundIDTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="아이디 : ahr******"
            android:textSize="20sp"
            android:fontFamily="@font/pretendard_bold"
            android:layout_marginStart="24dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <TextView
            android:id="@+id/copyButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/baseline_content_copy_24"
            android:drawableTint="@color/blue"
            android:drawablePadding="4dp"
            android:text="복사"
            android:fontFamily="@font/pretendard_bold"
            android:textColor="@color/blue"
            android:textSize="16sp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toTopOf="@id/foundIDTextView"
            app:layout_constraintBottom_toBottomOf="@id/foundIDTextView"
            app:layout_constraintEnd_toEndOf="@id/resultBox"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/loginButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/resultBox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/blue"
        android:text="로그인"
        android:textStyle="bold"
        android:textSize="18sp"
        app:cornerRadius="12dp"
        android:fontFamily="@font/pretendard_bold"
        android:layout_marginHorizontal="24dp"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/findPWButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/loginButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:backgroundTint="@color/gray"
        android:text="비밀번호 찾기"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="18sp"
        app:cornerRadius="12dp"
        android:fontFamily="@font/pretendard_bold"
        android:layout_marginHorizontal="24dp"
        />



</androidx.constraintlayout.widget.ConstraintLayout>