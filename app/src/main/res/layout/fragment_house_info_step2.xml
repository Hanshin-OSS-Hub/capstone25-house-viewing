<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/coolgray"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#E8EDF5"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeWidth="0dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="4dp"
                app:checkedButton="@id/monthButton"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/monthButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:backgroundTint="@color/toggle_bg_selector"
                    android:fontFamily="@font/pretendard_bold"
                    android:includeFontPadding="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="월세"
                    android:textColor="@color/toggle_text_selector"
                    android:textSize="16sp"
                    app:cornerRadius="8dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/yearButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:backgroundTint="@color/toggle_bg_selector"
                    android:fontFamily="@font/pretendard_bold"
                    android:includeFontPadding="false"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="전세"
                    android:textColor="@color/toggle_text_selector"
                    android:textSize="16sp"
                    app:cornerRadius="8dp"
                    app:strokeWidth="0dp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/paymentIcon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:src="@drawable/baseline_payments_24"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/buttonCardView" />

        <TextView
            android:id="@+id/paymentLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="-7dp"
            android:fontFamily="@font/pretendard_bold"
            android:text="임대 비용"
            android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/paymentIcon"
            app:layout_constraintTop_toTopOf="@id/paymentIcon" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/paymentCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/paymentIcon"
            app:layout_constraintTop_toBottomOf="@id/paymentIcon"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/monthSection"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp">

                <TextView
                    android:id="@+id/depositLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendard_bold"
                    android:text="보증금"
                    android:textColor="@color/textgray"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/depositInputBox"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:backgroundTint="@color/textviewgray"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/depositLabel">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/depositEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="start|center_vertical"
                        android:hint="0"
                        android:inputType="number"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/depositWonText"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/depositWonText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_medium"
                        android:includeFontPadding="false"
                        android:text="원"
                        android:textColor="@color/textgray"
                        android:textSize="20sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>


                <TextView
                    android:id="@+id/monthLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/pretendard_bold"
                    android:includeFontPadding="false"
                    android:text="월 임대료"
                    android:textColor="@color/textgray"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="@id/depositLabel"
                    app:layout_constraintTop_toBottomOf="@id/depositInputBox" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/monthInputBox"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:backgroundTint="@color/textviewgray"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/monthLabel"
                    app:layout_constraintTop_toBottomOf="@id/monthLabel">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/monthEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="start|center_vertical"
                        android:hint="0"
                        android:inputType="number"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/monthWonText"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/monthWonText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_medium"
                        android:includeFontPadding="false"
                        android:text="원"
                        android:textColor="@color/textgray"
                        android:textSize="20sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/monthManageLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/pretendard_bold"
                    android:includeFontPadding="false"
                    android:text="월 관리비"
                    android:textColor="@color/textgray"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="@id/depositLabel"
                    app:layout_constraintTop_toBottomOf="@id/monthInputBox" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/monthManageInputBox"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:backgroundTint="@color/textviewgray"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/monthManageLabel"
                    app:layout_constraintTop_toBottomOf="@id/monthManageLabel">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/monthManageEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="start|center_vertical"
                        android:hint="0"
                        android:inputType="number"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/monthManageWonText"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/monthManageWonText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_medium"
                        android:includeFontPadding="false"
                        android:text="원"
                        android:textColor="@color/textgray"
                        android:textSize="20sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/noManageCheckBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendard_bold"
                    android:includeFontPadding="false"
                    android:text="관리비 미부과"
                    android:textColor="@color/selector_checkbox_text"
                    android:textSize="16sp"
                    app:buttonTint="@color/selector_checkbox"
                    app:layout_constraintStart_toStartOf="@id/monthManageLabel"
                    app:layout_constraintTop_toBottomOf="@id/monthManageInputBox" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/yearSection"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/yearDepositLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendard_bold"
                    android:text="보증금"
                    android:textColor="@color/textgray"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/yearDepositInputBox"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:backgroundTint="@color/textviewgray"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/yearDepositLabel">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/yearDepositEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="start|center_vertical"
                        android:hint="0"
                        android:inputType="number"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/yearDepositWonText"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/yearDepositWonText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_medium"
                        android:includeFontPadding="false"
                        android:text="원"
                        android:textColor="@color/textgray"
                        android:textSize="20sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/yearManageLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/pretendard_bold"
                    android:includeFontPadding="false"
                    android:text="월 관리비"
                    android:textColor="@color/textgray"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="@id/yearDepositLabel"
                    app:layout_constraintTop_toBottomOf="@id/yearDepositInputBox" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/yearManageInputBox"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:backgroundTint="@color/textviewgray"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@id/yearManageLabel"
                    app:layout_constraintTop_toBottomOf="@id/yearManageLabel">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/yearManageEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="start|center_vertical"
                        android:hint="0"
                        android:inputType="number"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/yearManageWonText"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/yearManageWonText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendard_medium"
                        android:includeFontPadding="false"
                        android:text="원"
                        android:textColor="@color/textgray"
                        android:textSize="20sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/yearNoManageCheckBox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendard_bold"
                    android:includeFontPadding="false"
                    android:text="관리비 미부과"
                    android:textColor="@color/selector_checkbox_text"
                    android:textSize="16sp"
                    app:buttonTint="@color/selector_checkbox"
                    app:layout_constraintStart_toStartOf="@id/yearManageLabel"
                    app:layout_constraintTop_toBottomOf="@id/yearManageInputBox" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/calenderIcon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:src="@drawable/baseline_calendar_month_24"
            app:layout_constraintStart_toStartOf="@id/paymentIcon"
            app:layout_constraintTop_toBottomOf="@id/paymentCardView" />

        <TextView
            android:id="@+id/calenderLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="-7dp"
            android:fontFamily="@font/pretendard_bold"
            android:text="계약 주요 날짜"
            android:textSize="24sp"
            app:layout_constraintStart_toEndOf="@id/calenderIcon"
            app:layout_constraintTop_toTopOf="@id/calenderIcon" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/calenderCardView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/calenderIcon"
            app:layout_constraintTop_toBottomOf="@id/calenderIcon"
            app:strokeWidth="0dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/calenderContentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/moveInDateLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendard_bold"
                    android:text="전입일"
                    android:textColor="@color/textgray"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/moveInDateLayout"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:backgroundTint="@color/textviewgray"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/moveInDateLabel">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/moveInDateEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="start|center_vertical"
                        android:hint="YYYY-MM-DD"
                        android:inputType="number"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/fixedDateIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/baseline_edit_calendar_24"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/confirmDateLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendard_bold"
                    android:text="확정일자"
                    android:textColor="@color/textgray"
                    android:textSize="16sp"
                    android:layout_marginTop="24dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/moveInDateLayout" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/confirmDateLayout"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_rounded_edittext"
                    android:backgroundTint="@color/textviewgray"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/confirmDateLabel">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/confirmDateEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="start|center_vertical"
                        android:hint="YYYY-MM-DD"
                        android:inputType="number"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/confirmDateIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/baseline_edit_calendar_24"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>