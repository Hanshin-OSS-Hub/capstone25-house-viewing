<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="5dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/gray">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/emptyhomeicon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_circle_sheet_white"
            android:backgroundTint="@color/grayblue"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/outline_home_work_24"
                android:backgroundTint="@color/blue"
                android:layout_gravity="center"/>
        </FrameLayout>

        <TextView
            android:id="@+id/emptyTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="등록된 집이 없어요"
            android:textSize="20sp"
            android:fontFamily="@font/pretendard_bold"
            android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/emptyhomeicon"
            android:layout_marginTop="12dp"
            />

        <TextView
            android:id="@+id/emptyDescText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="집을 추가하면 LTV와 감시 상태를 \n 한눈에 확인할 수 있어요"
            android:textSize="14sp"
            android:gravity="center"
            android:fontFamily="@font/pretendard_medium"
            android:includeFontPadding="false"
            android:textColor="@color/textgray"
            app:layout_constraintTop_toBottomOf="@id/emptyTitleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/plusHouseButton"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:text="+ 집 추가하기"
            android:textSize="18dp"
            android:fontFamily="@font/pretendard_bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/blue"
            app:cornerRadius="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/emptyDescText"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="12dp"
            />




    </androidx.constraintlayout.widget.ConstraintLayout>


</com.google.android.material.card.MaterialCardView>