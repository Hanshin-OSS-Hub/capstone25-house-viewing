<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_white"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="10dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="44dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_handle_bar" />

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/pretendard_bold"
        android:text="집 정보 수정"
        android:textColor="@color/black"
        android:textSize="20sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="집 닉네임"
        android:textColor="@color/textgray"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/nameEditText"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_inline_edit_field"
        android:fontFamily="@font/pretendard_medium"
        android:hint="집 닉네임"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:paddingHorizontal="14dp"
        android:textColor="@color/black"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/pretendard_medium"
        android:text="주소"
        android:textColor="@color/textgray"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/detailAddressEditText"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_inline_edit_field"
        android:fontFamily="@font/pretendard_medium"
        android:hint="주소"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:paddingHorizontal="14dp"
        android:textColor="@color/black"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/cancelButton"
            android:layout_width="76dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_sheet_cancel_button"
            android:fontFamily="@font/pretendard_bold"
            android:gravity="center"
            android:text="취소"
            android:textColor="#7A8599"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/saveButton"
            android:layout_width="76dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_sheet_save_button"
            android:fontFamily="@font/pretendard_bold"
            android:gravity="center"
            android:text="저장"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>
