<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_dialog_card"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp"
    android:elevation="8dp">

    <FrameLayout
        android:id="@+id/iconWrap"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_circle_sheet_white"
        android:backgroundTint="#FFF0F0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/baseline_warning_24"
            app:tint="@color/red"/>
    </FrameLayout>
    
    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="등기부등본 변경 감지"
        android:textSize="20sp"
        android:fontFamily="@font/pretendard_bold"
        android:textColor="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconWrap"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/descTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/titleTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:text="해당 부동산 등기에 변경이 있어요."
        android:textSize="14sp"
        android:fontFamily="@font/pretendard_medium"
        android:textColor="@color/darkgray"
        />

    <TextView
        android:id="@+id/descTextView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/descTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="위험 요소를 지금 분석해 드릴까요?"
        android:textSize="14sp"
        android:fontFamily="@font/pretendard_medium"
        android:textColor="@color/darkgray"
        />


    <LinearLayout
        android:id="@+id/analysisItem"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/descTextView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="vertical"
        android:background="@drawable/bg_rounded_edittext"
        android:backgroundTint="@color/coolgray"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp"
        >
        <TextView
            android:id="@+id/secondTitleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="분석 시 제공되는 정보"
            android:textSize="12sp"
            android:fontFamily="@font/pretendard_medium"
            android:includeFontPadding="false"
            android:textColor="@color/textgray"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp"
            >
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_sheet_white"
                android:backgroundTint="@color/grayblue">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/outline_analytics_24"
                    app:tint="@color/blue2" />
            </FrameLayout>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="@font/pretendard_bold"
                android:text="LTV 계산 및 위험도 평가"
                android:textColor="@color/black"
                android:includeFontPadding="false"
                android:textSize="13sp" />
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/round_check_circle_24"
                app:tint="@color/blue2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp"
            >
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_sheet_white"
                android:backgroundTint="@color/grayblue">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/outline_description_24"
                    app:tint="@color/blue2" />
            </FrameLayout>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="@font/pretendard_bold"
                android:text="선순위 채권 유형 변경 내역"
                android:textColor="@color/black"
                android:includeFontPadding="false"
                android:textSize="13sp" />
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/round_check_circle_24"
                app:tint="@color/blue2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp"
            >
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_sheet_white"
                android:backgroundTint="@color/grayblue">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/outline_quiz_24"
                    app:tint="@color/blue2" />
            </FrameLayout>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="@font/pretendard_bold"
                android:text="법적 용어 가이드"
                android:textColor="@color/black"
                android:includeFontPadding="false"
                android:textSize="13sp" />
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/round_check_circle_24"
                app:tint="@color/blue2" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="12dp"
            >
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_sheet_white"
                android:backgroundTint="@color/grayblue">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/outline_payments_24"
                    app:tint="@color/blue2" />
            </FrameLayout>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="@font/pretendard_bold"
                android:text="회수 금액 및 대응 가이드라인"
                android:textColor="@color/black"
                android:includeFontPadding="false"
                android:textSize="13sp" />
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/round_check_circle_24"
                app:tint="@color/blue2" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/analysisButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:text="분석 시작하기"
        android:textSize="15sp"
        android:fontFamily="@font/pretendard_bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/blue"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/analysisItem"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/buttonLater"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/pretendard_medium"
        android:padding="8dp"
        android:text="나중에 할게요"
        android:textColor="@color/textgray"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/analysisButton" />

</androidx.constraintlayout.widget.ConstraintLayout>