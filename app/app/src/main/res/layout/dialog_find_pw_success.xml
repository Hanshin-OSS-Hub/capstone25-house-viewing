<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_bottom_sheet_white"
    android:paddingBottom="40dp">

    <View
        android:id="@+id/handleBar"
        android:layout_width="40dp"
        android:layout_height="5dp"
        android:background="@drawable/bg_handle_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        />
    <FrameLayout
        android:id="@+id/iconArea"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_circle_sheet_white"
        android:backgroundTint="@color/grayblue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/handleBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/round_check_circle_24"
            android:layout_gravity="center"/>
    </FrameLayout>

    <TextView
        android:id="@+id/pwFindSuccessTextview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="본인 확인 완료"
        android:textSize="24dp"
        app:layout_constraintTop_toBottomOf="@id/iconArea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/pretendard_bold"
        />

    <TextView
        android:id="@+id/pwFindSuccessinfoTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="본인 확인이 완료되었습니다."
        app:layout_constraintTop_toBottomOf="@id/pwFindSuccessTextview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:textColor="@color/textgray"
        android:fontFamily="@font/pretendard_medium"
        android:textSize="16dp"
        />

    <TextView
        android:id="@+id/pwFindSuccessinfoTextView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="새로운 비밀번호로 변경해주세요."
        app:layout_constraintTop_toBottomOf="@id/pwFindSuccessinfoTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:textColor="@color/textgray"
        android:fontFamily="@font/pretendard_medium"
        android:textSize="16dp"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/resettingPWButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/pwFindSuccessinfoTextView2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/blue"
        android:text="비밀번호 재설정"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        app:cornerRadius="12dp"
        android:fontFamily="@font/pretendard_bold"
        android:layout_marginHorizontal="24dp"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/closeButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toBottomOf="@id/resettingPWButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:backgroundTint="@color/gray"
        android:text="닫기"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="18sp"
        app:cornerRadius="12dp"
        android:fontFamily="@font/pretendard_bold"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="4dp"
        />



</androidx.constraintlayout.widget.ConstraintLayout>