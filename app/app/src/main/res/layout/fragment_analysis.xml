<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/coolgray">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/analysisScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="분석 기록"
                android:textColor="@color/black"
                android:textSize="26sp"
                android:fontFamily="@font/pretendard_bold"
                android:includeFontPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/filterIcon" />

            <ImageView
                android:id="@+id/filterIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/outline_more_horiz_24"
                app:tint="@color/icongray"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/titleTextView"
                app:layout_constraintBottom_toBottomOf="@id/titleTextView" />

            <LinearLayout
                android:id="@+id/tabLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/titleTextView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tabMyRecord"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="내 진단 기록"
                    android:textColor="@color/blue"
                    android:textSize="14sp"
                    android:fontFamily="@font/pretendard_bold"
                    android:paddingVertical="10dp" />

                <TextView
                    android:id="@+id/tabAutoRecord"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="자동 감지 기록"
                    android:textColor="@color/textgray"
                    android:textSize="14sp"
                    android:fontFamily="@font/pretendard_medium"
                    android:paddingVertical="10dp" />
            </LinearLayout>

            <View
                android:id="@+id/tabIndicator"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:background="@color/blue"
                app:layout_constraintTop_toBottomOf="@id/tabLayout"
                app:layout_constraintStart_toStartOf="@id/tabLayout" />


            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/searchLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/tabIndicator"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:startIconDrawable="@drawable/round_search_24"
                app:startIconTint="@color/icongray"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/searchEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="닉네임 또는 주소 검색..."
                    android:textColorHint="@color/hintcolor"
                    android:fontFamily="@font/pretendard_medium"
                    android:paddingVertical="10dp" />
            </com.google.android.material.textfield.TextInputLayout>


            <com.google.android.material.chip.ChipGroup
                android:id="@+id/filterChipGroup"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/searchLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:singleSelection="true"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="전체"
                    android:checked="true"
                    android:fontFamily="@font/pretendard_bold"
                    android:textColor="@color/black"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStartPadding="10dp"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStrokeWidth="0.8dp"
                    app:chipIconVisible="true"
                    app:chipIcon="@drawable/ic_chip_dot"
                    app:chipIconTint="@color/icongray"
                    app:chipIconSize="8dp"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="고위험"
                    android:fontFamily="@font/pretendard_bold"
                    android:textColor="@color/black"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStartPadding="10dp"
                    app:chipStrokeWidth="0.8dp"
                    app:chipIconVisible="true"
                    app:chipIcon="@drawable/ic_chip_dot"
                    app:chipIconTint="@color/red"
                    app:chipIconSize="8dp"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAmber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="주의"
                    android:fontFamily="@font/pretendard_bold"
                    android:textColor="@color/black"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStartPadding="10dp"
                    app:chipStrokeWidth="0.8dp"
                    app:chipIconVisible="true"
                    app:chipIcon="@drawable/ic_chip_dot"
                    app:chipIconTint="@color/amber"
                    app:chipIconSize="8dp"
                    app:checkedIconVisible="false" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBlue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="안전"
                    android:fontFamily="@font/pretendard_bold"
                    android:textColor="@color/black"
                    app:chipBackgroundColor="@color/chip_bg_selector"
                    app:chipStrokeColor="@color/chip_stroke_selector"
                    app:chipStartPadding="10dp"
                    app:chipStrokeWidth="0.8dp"
                    app:chipIconVisible="true"
                    app:chipIcon="@drawable/ic_chip_dot"
                    app:chipIconTint="@color/blue2"
                    app:chipIconSize="8dp"
                    app:checkedIconVisible="false" />

            </com.google.android.material.chip.ChipGroup>

            <LinearLayout
                android:id="@+id/emptyLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/filterChipGroup"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"

                >

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/outline_description_24"
                    app:tint="@color/icongray" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="아직 진단 기록이 없습니다"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/pretendard_bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="무료 진단을 시작하면 기록이 여기에 표시됩니다."
                    android:textColor="@color/textgray"
                    android:textSize="14sp"
                    android:fontFamily="@font/pretendard_medium" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recordRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingBottom="16dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/filterChipGroup"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>