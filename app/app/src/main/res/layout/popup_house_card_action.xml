<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:minWidth="120dp"
    android:orientation="vertical"
    android:background="@drawable/bg_popup_compact_surface"
    android:paddingVertical="4dp">

    <LinearLayout
        android:id="@+id/actionEditRow"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/bg_popup_row_selector">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_edit_24"
            app:tint="@color/darkgray"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/pretendard_medium"
            android:text="수정하기"
            android:textColor="@color/darkgray"
            android:textSize="15sp"
            android:includeFontPadding="false" />
    </LinearLayout>

    <View
        android:layout_width="84dp"
        android:layout_height="1dp"
        android:layout_gravity="center_horizontal"
        android:background="#EEF2F6" />

    <LinearLayout
        android:id="@+id/actionDeleteRow"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/bg_popup_delete_row_selector">


        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/outline_delete_24"
            app:tint="#EF4444"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/pretendard_medium"
            android:text="삭제하기"
            android:textColor="#EF4444"
            android:textSize="15sp"
            android:includeFontPadding="false" />
    </LinearLayout>
</LinearLayout>