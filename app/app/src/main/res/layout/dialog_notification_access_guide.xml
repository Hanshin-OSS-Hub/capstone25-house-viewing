<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_white"
    android:paddingHorizontal="24dp"
    android:paddingBottom="32dp">

    <View
        android:id="@+id/handleBar"
        android:layout_width="40dp"
        android:layout_height="5dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_handle_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/iconWrap"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_circle_sheet_white"
        android:backgroundTint="@color/grayblue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/handleBar">

        <ImageView
            android:id="@+id/iconBell"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/outline_notifications_active_24"
            app:tint="@color/blue" />
    </FrameLayout>

    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/pretendard_bold"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="알림 접근 권한 허용 안내"
        android:textColor="@color/black"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconWrap" />

    <TextView
        android:id="@+id/descText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/pretendard_medium"
        android:gravity="center"
        android:includeFontPadding="false"
        android:lineSpacingExtra="4dp"
        android:text="설정에서 알림 접근을 허용해 주시면\n실시간 감시 서비스를 정상적으로 이용하실 수 있습니다."
        android:textColor="@color/textgray"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <LinearLayout
        android:id="@+id/featureBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_rounded_edittext"
        android:backgroundTint="#F0F4FC"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/descText">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pretendard_medium"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="2dp"
            android:text="등기부등본에 압류, 근저당 등 권리 변동이 있으면,\n즉시 푸시 알림으로 알려드려요."
            android:textColor="@color/darkgray"
            android:textSize="13sp" />
    </LinearLayout>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/goButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/blue"
        android:fontFamily="@font/pretendard_bold"
        android:includeFontPadding="false"
        android:text="알림 허용하러 가기 →"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/featureBox" />

    <TextView
        android:id="@+id/buttonLater"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/pretendard_medium"
        android:padding="12dp"
        android:text="다음에 하기"
        android:textColor="@color/textgray"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/goButton" />

</androidx.constraintlayout.widget.ConstraintLayout>