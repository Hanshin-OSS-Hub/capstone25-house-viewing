# .env.example - 이 파일을 복사해서 .env로 만들고 값을 채워주세요

# Groq API 키 (https://console.groq.com 에서 무료 발급)
XAI_API_KEY=your_groq_api_key_here

# 사용할 모델 (기본값: llama-3.3-70b-versatile)
GROK_MODEL=llama-3.3-70b-versatile

# AI 실패 시 폴백 여부
# false (기본) = AI 필수, 실패 시 HTTP 503 반환
# true         = AI 실패해도 기본 텍스트로 PDF 생성
GEMINI_FALLBACK_ENABLED=false
